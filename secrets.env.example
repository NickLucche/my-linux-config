# Example secrets/env file. Copy this to ~/.config/dev-env/secrets.env on each
# machine and fill in real values. dot_zshrc sources that path if it exists.
#
# This file is NEVER committed and NOT managed by chezmoi — carry the real
# ~/.config/dev-env/secrets.env around out-of-band (scp/USB), so secrets stay
# identical everywhere without living in git.
#
#   mkdir -p ~/.config/dev-env
#   cp secrets.env.example ~/.config/dev-env/secrets.env
#   $EDITOR ~/.config/dev-env/secrets.env

# Hugging Face
export HF_TOKEN=""
# export HF_HOME="$HOME/.cache/huggingface"

# Add other tokens/keys as needed (WANDB_API_KEY, OPENAI_API_KEY, ...)
